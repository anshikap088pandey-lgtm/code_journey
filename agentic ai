def assess_readiness(profile):
    """Return a readiness score and feedback."""
    score = 0
    if profile["skill_level"] == "advanced": score += 40
    elif profile["skill_level"] == "intermediate": score += 20
    if profile["placement_ready"]: score += 30
    if len(profile["weak_areas"]) == 0: score += 30
    return f"Readiness score: {score}/100. Focus on: {', '.join(profile['weak_areas'])}"
def generate_roadmap(profile):
    """Return a week-by-week study plan."""
    level = profile["skill_level"]
    domain = profile["domain"]
    weak = profile["weak_areas"]
    
    roadmap = f"# {level.title()} {domain} Roadmap for {profile['name']}\n"
    if level == "beginner":
        roadmap += "Week 1-2: Fundamentals of " + domain + "\n"
        roadmap += "Week 3-4: Build a mini project\n"
    elif level == "intermediate":
        roadmap += "Week 1: Strengthen weak areas: " + ", ".join(weak) + "\n"
        roadmap += "Week 2-3: Advanced topics + portfolio project\n"
    else:  # advanced
        roadmap += "Week 1: System design & optimization\n"
        roadmap += "Week 2-3: Mock interviews + competitive programming\n"
    roadmap += "Week 4: Apply to 10 companies/day\n"
    return roadmap
