const express = require("express");
const app = express();

app.use(express.json());
app.use(express.static(".")); // frontend serve karega

app.post("/analyze", (req, res) => {
let { skills, goal } = req.body;

let result = "=== AI Career Coach Analysis ===\n\n";

// Skill gap
if (!skills.toLowerCase().includes("dsa")) {
result += "❌ Weak Area: DSA\n👉 Action: Solve 5 problems daily for 7 days\n\n";
}

// Goal based suggestion
if (goal.toLowerCase().includes("developer")) {
result += "🎯 Goal: Software Developer\n👉 Apply to companies like TCS, Infosys, Wipro\n\n";
}

// Strong candidate detection
if (skills.toLowerCase().includes("python")) {
result += "🔥 Strong Profile Detected\n👉 Try higher companies / startups\n\n";
}

// Mentor matching
if (!skills.toLowerCase().includes("project")) {
result += "🧑‍🏫 Mentor Assigned: Beginner Mentor\n\n";
} else {
result += "🧑‍🏫 Mentor Assigned: Advanced Mentor\n\n";
}

// Alert system
result += "⚠ Alert: Apply to at least 3 companies this week\n\n";

// Daily task
result += "📅 Daily Task: Practice coding for 2 hours\n";

res.json({ result });
});

app.listen(3000, () => console.log("Server running on port 3000"));<!DOCTYPE html>

